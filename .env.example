# GitHub / GHCR
GITHUB_ORG=phutrandjv
# GitHub org owning the GHCR packages (used by deploy.sh --update to pull images)
GHCR_ORG=tranphu-devops
# GitHub Personal Access Token with read:packages scope (for docker login on server)
GHCR_TOKEN=

# PostgreSQL
POSTGRES_PASSWORD=changeme

# Connection strings (multi-schema, same DB)
USER_DATABASE_URL=postgres://postgres:changeme@postgres:5432/quizdb?search_path=quiz_users
EXAM_DATABASE_URL=postgres://postgres:changeme@postgres:5432/quizdb?search_path=quiz_exams
SUBMISSION_DATABASE_URL=postgres://postgres:changeme@postgres:5432/quizdb?search_path=quiz_submissions

# Auth (shared between GoTrue and all backend services)
JWT_SECRET=change_this_to_a_random_secret_min_32_chars

# Internal service-to-service key
INTERNAL_API_KEY=change_this_internal_secret_min_32_chars

# GoTrue / SSO
SITE_URL=http://localhost
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS / Lightsail Object Storage (for image uploads)
AWS_ACCESS_KEY_ID=your_lightsail_access_key_id
AWS_SECRET_ACCESS_KEY=your_lightsail_secret_access_key
AWS_BUCKET=your_bucket_name
AWS_REGION=ap-southeast-1
# Optional: custom endpoint for Lightsail (leave empty to use standard S3)
AWS_ENDPOINT=
# Public base URL for uploaded files (e.g. https://mybucket.s3.ap-southeast-1.amazonaws.com)
AWS_PUBLIC_URL=

# Image tag
TAG=latest

# API response encryption (production only — leave blank in dev)
# Generate with: node scripts/generate-api-key.js
# Only API_ENCRYPTION_KEY is needed; public key is served at runtime by user-service.
API_ENCRYPTION_KEY=                  # EC P-256 private key, base64 — backend only, keep secret
